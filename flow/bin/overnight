#!/usr/bin/env bash
# overnight — parallel gnhf + no-mistakes. Portable via flow/.
set -uo pipefail
_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_BIN/../lib/config.sh"
flow_init

die() { echo "overnight: $*" >&2; exit 1; }
log() { echo "[overnight $(date +%H:%M:%S)] $*"; }

GNHF="$_BIN/gnhf"
NM="$_BIN/no-mistakes"
JOBS=() VERIFY_SPECS=()
PARALLEL="$FLOW_OVERNIGHT_PARALLEL" BUDGET="$FLOW_OVERNIGHT_BUDGET"
MAX_STEPS="$FLOW_OVERNIGHT_MAX_STEPS" VALIDATE="$FLOW_VALIDATE"
BASE_CONTEXT="$FLOW_BASE_CONTEXT" BASE_BRANCH="$FLOW_BASE_BRANCH"
SKIP_NM=0 DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --job)
      spec="${2:?}"
      if [[ "$spec" == *:* ]]; then JOBS+=("${spec%%:*}"); VERIFY_SPECS+=("${spec#*:}")
      else JOBS+=("$spec"); VERIFY_SPECS+=(""); fi
      shift 2 ;;
    --parallel) PARALLEL="${2:?}"; shift 2 ;;
    --budget-usd) BUDGET="${2:?}"; shift 2 ;;
    --max-steps) MAX_STEPS="${2:?}"; shift 2 ;;
    --validate) VALIDATE="${2:?}"; shift 2 ;;
    --base-context) BASE_CONTEXT="${2:?}"; shift 2 ;;
    --base) BASE_BRANCH="${2:?}"; shift 2 ;;
    --skip-no-mistakes) SKIP_NM=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) echo "overnight — flow $FLOW_ROOT"; exit 0 ;;
    *) die "unknown: $1" ;;
  esac
done

[[ ${#JOBS[@]} -gt 0 ]] || die "need --job PLAN.md"
cd "$REPO_ROOT" || die "no repo"
[[ -n "$(git status --porcelain)" ]] && die "dirty tree"

RUN_ID="$(date +%Y%m%d-%H%M%S)"
RUN_DIR="$FLOW_ARTIFACTS/overnight/$RUN_ID"
mkdir -p "$RUN_DIR"
slug_from_plan() { basename "$1" .md | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | cut -c1-32; }

PIDS=() JOB_SLUGS=() i=0
for plan in "${JOBS[@]}"; do
  plan_abs="$([[ "$plan" = /* ]] && echo "$plan" || echo "$REPO_ROOT/$plan")"
  [[ -f "$plan_abs" ]] || die "not found: $plan"
  slug="$(slug_from_plan "$plan_abs")"; JOB_SLUGS+=("$slug")
  [[ "$DRY_RUN" == "1" ]] && { log "DRY: $plan_abs"; i=$((i+1)); continue; }

  while [[ $(jobs -rp 2>/dev/null | wc -l) -ge $PARALLEL ]]; do sleep 5; done
  if [[ ${#JOBS[@]} -eq 1 ]]; then workdir="$REPO_ROOT"; run_plan="$plan_abs"
  else
    workdir="$REPO_ROOT/../$(basename "$REPO_ROOT")-overnight-$slug"
    [[ -d "$workdir" ]] || git worktree add -b "overnight/$slug" "$workdir" "$BASE_BRANCH" 2>/dev/null \
      || git worktree add "$workdir" "$BASE_BRANCH" || die "worktree failed"
    cp "$plan_abs" "$workdir/plan.md"; run_plan="$workdir/plan.md"
  fi
  verify="${VERIFY_SPECS[$i]:-}"; verify_arg=""
  if [[ -n "$verify" ]]; then
    vsrc="$([[ "$verify" = /* ]] && echo "$verify" || echo "$REPO_ROOT/$verify")"
    [[ -f "$vsrc" ]] || die "verify spec: $verify"
    [[ "$workdir" != "$REPO_ROOT" ]] && mkdir -p "$workdir/$(dirname "$verify")" && cp "$vsrc" "$workdir/$verify"
    verify_arg="$verify"
  fi
  (
    rc=0
    (cd "$workdir" && "$GNHF" -f "$run_plan" --validate "$VALIDATE" --max-steps "$MAX_STEPS" --budget-usd "$BUDGET" \
      ${BASE_CONTEXT:+--base-context "$BASE_CONTEXT"} --branch-prefix "overnight/${slug}-") \
      >"$RUN_DIR/${slug}-gnhf.log" 2>&1 || rc=1
    [[ $rc -eq 0 && "$SKIP_NM" != "1" ]] && {
      args=(-y --base "$BASE_BRANCH" --no-push)
      [[ -n "$verify_arg" ]] && args+=(--verify-spec "$verify_arg")
      (cd "$workdir" && "$NM" "${args[@]}") >"$RUN_DIR/${slug}-nm.log" 2>&1 || rc=$?
    }
    echo "$rc" >"$RUN_DIR/${slug}.exit"
  ) &
  PIDS+=($!); i=$((i+1))
done

[[ "$DRY_RUN" == "1" ]] && exit 0
for pid in "${PIDS[@]}"; do wait "$pid" || true; done

fail=0; echo "{\"run_id\":\"$RUN_ID\",\"jobs\":[" >"$RUN_DIR/summary.json"
j=0
for slug in "${JOB_SLUGS[@]}"; do
  ec=1; [[ -f "$RUN_DIR/${slug}.exit" ]] && ec="$(cat "$RUN_DIR/${slug}.exit")"
  case "$ec" in 0) st=pass;; 2) st=needs_human; fail=2;; *) st=fail; [[ $fail -ne 2 ]] && fail=1;; esac
  [[ $j -gt 0 ]] && echo -n "," >>"$RUN_DIR/summary.json"
  printf '{"slug":"%s","status":"%s","exit":%s}' "$slug" "$st" "$ec" >>"$RUN_DIR/summary.json"
  j=$((j+1))
done
echo "]}" >>"$RUN_DIR/summary.json"
cat "$RUN_DIR/summary.json"
[[ $fail -eq 0 ]] && exit 0; [[ $fail -eq 2 ]] && exit 2; exit 1
