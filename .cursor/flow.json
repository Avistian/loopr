{
  "base_branch": "main",
  "validate": "uv run pytest -m 'not e2e'",
  "e2e": "uv run pytest -m e2e",
  "format": "true",
  "base_context": "CONTEXT.md",
  "capability_verify_spec": ".cursor/capability-verify.json",
  "artifacts_dir": "artifacts",
  "format_on_edit": {
    "*.py": "uv run ruff format {file}"
  },
  "gnhf": {
    "max_steps": 50,
    "budget_usd": 20
  },
  "overnight": {
    "parallel": 1,
    "max_steps": 80,
    "budget_usd": 80
  }
}
